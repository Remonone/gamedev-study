.achievement-item__header {
    flex-direction: row;
    align-items: center;
    column-gap: 8px;
}

.achievement-item__icon {
    width: 34px;
    height: 34px;
    background-color: rgb(196, 211, 229);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(127, 147, 170);
    border-right-color: rgb(127, 147, 170);
    border-bottom-color: rgb(127, 147, 170);
    border-left-color: rgb(127, 147, 170);
