}

.building-category-tab {
    flex-grow: 1;
    min-height: 0;
}

.category-tab-view #unity-tab-view__header-container {
    flex-grow: 0;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-content: flex-start;
    row-gap: 6px;
    column-gap: 6px;
    max-height: 80px;
    padding-bottom: 8px;
