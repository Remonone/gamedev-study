    border-left-width: 1px;
    border-top-color: rgb(127, 147, 170);
    border-right-color: rgb(127, 147, 170);
    border-bottom-color: rgb(127, 147, 170);
    border-left-color: rgb(127, 147, 170);
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-bottom-left-radius: 2px;
    -unity-background-scale-mode: scale-to-fit;
}

.artifact-selection-text {
    flex-grow: 1;
    min-width: 0;
}

.artifact-selection-name {
    color: rgb(25, 39, 58);
    -unity-font-style: bold;
}

.artifact-selection-description {
    color: rgb(57, 77, 99);
    white-space: normal;
}

.artifacts-placeholder {
    flex-grow: 1;
    min-height: 0;
    align-items: center;
    justify-content: center;
    background-color: rgb(232, 241, 251);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-color: rgb(166, 186, 209);
    border-right-color: rgb(166, 186, 209);
    border-bottom-color: rgb(166, 186, 209);
    border-left-color: rgb(166, 186, 209);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
}

.artifacts-placeholder-text {
    color: rgb(73, 93, 116);
}

.upgrade-node-price {
}

.notification-center {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 320px;
    flex-direction: column;
    align-items: stretch;
}

.notification {
    width: 100%;
    flex-direction: row;
    flex-shrink: 0;
    align-items: center;
    margin-bottom: 8px;
    padding: 10px;
    border-radius: 8px;
    background-color: rgba(30, 30, 35, 0.95);
    opacity: 0;
    transition-property: opacity, translate;
    transition-duration: 0.25s, 0.25s;
}

.notification--visible {
    opacity: 1;
    translate: 0 0;
}

.notification--closing {
    opacity: 0;
    translate: 40px 0;
}

.notification__icon {
    width: 40px;
    height: 40px;
    margin-right: 10px;
    flex-shrink: 0;
}

.notification__text {
    flex-grow: 1;
    flex-shrink: 1;
}

.notification__title {
    -unity-font-style: bold;
    font-size: 14px;
    color: rgb(255, 255, 255);
}

.notification__message {
    font-size: 12px;
    color: rgb(200, 200, 205);
    white-space: normal;
}

.notification--achievement { border-left-width: 4px; border-left-color: rgb(255, 196, 0); }
.notification--reward      { border-left-width: 4px; border-left-color: rgb(120, 220, 120); }
.notification--info        { border-left-width: 4px; border-left-color: rgb(100, 170, 255); }
.notification--tutorial    { border-left-width: 4px; border-left-color: rgb(180, 140, 255); }
.notification--system      { border-left-width: 4px; border-left-color: rgb(150, 150, 150); }