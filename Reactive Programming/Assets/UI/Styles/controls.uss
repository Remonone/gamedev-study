}

.category-tab-view #unity-tab__header:checked {
    background-color: rgb(182, 206, 232);
    border-top-color: rgb(110, 137, 168);
    border-right-color: rgb(110, 137, 168);
    border-bottom-color: rgb(110, 137, 168);
    border-left-color: rgb(110, 137, 168);
}

.category-tab-view #unity-tab-view__content-container,
.category-tab-view #unity-tab__content-container {
    flex-grow: 1;
    min-height: 0;
    align-items: stretch;
    align-self: stretch;
}

.category-tab-view .unity-tab,
.category-tab-view .unity-tab #unity-tab__content-container,
.category-tab-view Tab,
.category-tab-view Tab #unity-tab__content-container {
    flex-grow: 1;
    min-height: 0;
    align-self: stretch;
}

.category-scroll {
    flex-grow: 1;
    min-height: 0;
    align-self: stretch;
}

.category-scroll #unity-content-and-vertical-scroll-container,
.category-scroll #unity-content-viewport {
    flex-grow: 1;
    min-height: 0;
    align-self: stretch;
}

.category-scroll #unity-content-container {
    flex-direction: column;
    flex-grow: 0;
    flex-shrink: 0;
    align-items: stretch;
    row-gap: 10px;
}

.category-content {
    flex-grow: 0;
    flex-shrink: 0;
    align-self: stretch;
    min-height: 1px;
    flex-direction: column;
    row-gap: 10px;
    padding-top: 6px;
    padding-right: 6px;
    padding-bottom: 6px;
    padding-left: 6px;
}

.upgrades-layout {
    flex-grow: 1;
    min-height: 0;
    flex-direction: column;
    row-gap: 10px;
}

.upgrades-workspace {
    flex-grow: 1;
    min-height: 210px;
    position: relative;
    overflow: hidden;
    background-color: rgba(0, 0, 0, 0);
}

.upgrade-tree-window {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    min-width: 320px;
    min-height: 220px;
    overflow: hidden;
    background-color: rgb(233, 241, 250);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-color: rgb(132, 152, 175);
    border-right-color: rgb(132, 152, 175);
    border-bottom-color: rgb(132, 152, 175);
    border-left-color: rgb(132, 152, 175);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
}

.upgrade-tree-header {
    height: 32px;
    flex-shrink: 0;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding-left: 10px;
    padding-right: 10px;
    background-color: rgb(184, 204, 225);
    border-bottom-width: 1px;
    border-bottom-color: rgb(125, 146, 170);
}

.upgrade-tree-header-title {
    color: rgb(31, 47, 65);
    -unity-font-style: bold;
}

.upgrade-tree-header-hint {
    color: rgb(62, 82, 104);
}

.upgrade-tree-viewport {
    flex-grow: 1;
    min-height: 0;
    position: relative;
    overflow: hidden;
    background-color: rgb(208, 223, 239);
}

.upgrade-tree-canvas {
    position: absolute;
    left: 0;
    top: 0;
    width: 2200px;
    height: 1400px;
}

.upgrade-connections-layer,
.upgrade-nodes-layer {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.upgrade-node {
    position: absolute;
    width: 32px;
    min-height: 32px;
    background-color: rgb(236, 244, 252);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
}

.upgrade-node--locked {
    border-top-color: rgb(153, 153, 153);
    border-right-color: rgb(153, 153, 153);
    border-bottom-color: rgb(153, 153, 153);
    border-left-color: rgb(153, 153, 153);
    background-color: rgb(218, 218, 218);
}

.upgrade-node--available {
    border-top-color: rgb(117, 150, 104);
    border-right-color: rgb(117, 150, 104);
    border-bottom-color: rgb(117, 150, 104);
    border-left-color: rgb(117, 150, 104);
}

.upgrade-node--inprogress {
    border-top-color: rgb(121, 139, 176);
    border-right-color: rgb(121, 139, 176);
    border-bottom-color: rgb(121, 139, 176);
    border-left-color: rgb(121, 139, 176);
}

.upgrade-node--completed {
    border-top-color: rgb(96, 144, 118);
    border-right-color: rgb(96, 144, 118);
    border-bottom-color: rgb(96, 144, 118);
    border-left-color: rgb(96, 144, 118);
    background-color: rgb(214, 236, 223);
}

.upgrade-node--selected {
    border-top-color: rgb(79, 118, 168);
    border-right-color: rgb(79, 118, 168);
    border-bottom-color: rgb(79, 118, 168);
    border-left-color: rgb(79, 118, 168);
}

.upgrade-node__icon {
    width: 100%;
    height: 100%;
    background-color: rgb(194, 211, 230);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(126, 146, 170);
    border-right-color: rgb(126, 146, 170);
    border-bottom-color: rgb(126, 146, 170);
    border-left-color: rgb(126, 146, 170);
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-bottom-left-radius: 2px;
    -unity-background-scale-mode: scale-to-fit;
}

.upgrade-node__title {
    color: rgb(22, 34, 50);
    -unity-font-style: bold;
    white-space: normal;
}

.upgrade-node__level {
    position: absolute;
    right: -12px;
    bottom: -12px;
    color: rgb(61, 80, 103);
}

.upgrade-node__state {
    margin-top: 6px;
    color: rgb(50, 70, 94);
}

.upgrade-node-details {
    flex-grow: 0;
    flex-shrink: 0;
    background-color: rgb(223, 235, 248);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-color: rgb(153, 173, 195);
    border-right-color: rgb(153, 173, 195);
    border-bottom-color: rgb(153, 173, 195);
    border-left-color: rgb(153, 173, 195);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    padding-top: 10px;
    padding-right: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
}

.upgrade-node-summary {
    flex-direction: row;
    align-items: center;
    column-gap: 10px;
}

.upgrade-node-icon {
    width: 42px;
    height: 42px;
    background-color: rgb(199, 215, 233);
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(131, 152, 176);
    border-right-color: rgb(131, 152, 176);
    border-bottom-color: rgb(131, 152, 176);
    border-left-color: rgb(131, 152, 176);
    border-top-left-radius: 2px;
    border-top-right-radius: 2px;
    border-bottom-right-radius: 2px;
    border-bottom-left-radius: 2px;
    -unity-background-scale-mode: scale-to-fit;
}

.upgrade-node-text {
    flex-grow: 1;
    min-width: 0;
}

.upgrade-node-name {
    color: rgb(24, 37, 54);
    -unity-font-style: bold;
}

.upgrade-node-state,
.upgrade-node-level {
    color: rgb(57, 76, 99);
}

.upgrade-node-description {
    margin-top: 8px;
    white-space: normal;
    color: rgb(45, 63, 87);
}

.upgrade-node-button {
    margin-top: 10px;
    width: 140px;
    height: 30px;
    align-self: flex-end;
    background-color: rgb(134, 162, 193);
    color: rgb(255, 255, 255);
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(94, 123, 156);
    border-right-color: rgb(94, 123, 156);
    border-bottom-color: rgb(94, 123, 156);
    border-left-color: rgb(94, 123, 156);
}

.upgrade-node-button:disabled {
    background-color: rgb(174, 186, 200);
    color: rgb(101, 112, 126);
}

.achievements-layout {
    flex-grow: 1;
    min-height: 0;
}

.achievements-list {
    flex-grow: 1;
    min-height: 0;
}

.achievements-list #unity-content-container {
    flex-direction: column;
    row-gap: 8px;
    padding-right: 4px;
}

.achievements-empty {
    padding-top: 10px;
    padding-right: 10px;
    padding-bottom: 10px;
    padding-left: 10px;
    color: rgb(74, 92, 115);
}

.achievement-item {
    flex-direction: column;
    background-color: rgb(230, 239, 248);
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-color: rgb(159, 177, 199);
    border-right-color: rgb(159, 177, 199);
    border-bottom-color: rgb(159, 177, 199);
    border-left-color: rgb(159, 177, 199);
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    padding-top: 8px;
