#StorageContent {
    flex-grow: 0;
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 6px;
    column-gap: 12px;
    padding-top: 10px;
    padding-right: 12px;
    padding-bottom: 10px;
    padding-left: 12px;
    background-color: rgb(220, 232, 245);
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    border-bottom-left-radius: 4px;
    border-top-width: 2px;
    border-right-width: 2px;
    border-bottom-width: 2px;
    border-left-width: 2px;
    border-top-color: rgb(169, 188, 209);
    border-right-color: rgb(169, 188, 209);
    border-bottom-color: rgb(169, 188, 209);
    border-left-color: rgb(169, 188, 209);
}

.storage-item {
    flex-direction: row;
    align-items: center;
    column-gap: 4px;
}

#StorageContent Label {
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
}

.storage-key {
    color: rgb(49, 64, 81);
    -unity-font-style: bold;
}

.storage-value {
    color: rgb(18, 34, 54);
    min-width: 32px;
}

#Display {
    flex-direction: column;
    min-height: 0;
}

.controls-content {
    flex-grow: 1;
    min-height: 0;
    margin-top: 14px;
}

.main-tab-view {
    flex-grow: 1;
    min-height: 0;
}

.main-tab {
    flex-grow: 1;
    min-height: 0;
}

.main-tab-view #unity-tab-view__header-container {
    flex-grow: 0;
    flex-shrink: 0;
    min-height: 36px;
    padding-bottom: 8px;
    overflow: hidden;
}

.main-tab-view #unity-tab-view__header-container .unity-scroll-view__horizontal-scroller,
.main-tab-view #unity-tab-view__header-container .unity-scroller,
.main-tab-view #unity-tab-view__header-container .unity-scroller__low-button,
.main-tab-view #unity-tab-view__header-container .unity-scroller__high-button,
.main-tab-view #unity-tab-view__header-container .unity-scroll-view__horizontal-scroller .unity-button,
.main-tab-view #unity-tab-view__header-container #unity-horizontal-scroller,
.main-tab-view #unity-tab-view__header-container #unity-low-button,
.main-tab-view #unity-tab-view__header-container #unity-high-button,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__scroll-button-left,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__scroll-button-right,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__left-scroll-button,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__right-scroll-button,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__previous-button,
.main-tab-view #unity-tab-view__header-container #unity-tab-view__next-button,
.main-tab-view #unity-tab-view__header-container .unity-tab-view__scroll-button,
.main-tab-view #unity-tab-view__header-container .unity-tab-view__scroll-button-left,
.main-tab-view #unity-tab-view__header-container .unity-tab-view__scroll-button-right,
.main-tab-view #unity-tab-view__header-container ScrollerButton,
.main-tab-view #unity-tab-view__header-container RepeatButton {
    display: none;
    width: 0;
    height: 0;
}

.main-tab-view #unity-tab-view__header-container .unity-scroll-view__content-viewport,
.main-tab-view #unity-tab-view__header-container #unity-content-viewport {
    overflow: visible;
}

.main-tab-view #unity-tab-view__header-container .unity-scroll-view__content-container,
.main-tab-view #unity-tab-view__header-container #unity-content-container,
.main-tab-view #unity-tab-view__tabs-container {
    flex-direction: row;
    flex-wrap: wrap;
    row-gap: 6px;
    column-gap: 6px;
}

.main-tab-view #unity-tab__header {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 110px;
    height: 32px;
    background-color: rgb(193, 210, 231);
    color: rgb(32, 47, 64);
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(141, 160, 182);
    border-right-color: rgb(141, 160, 182);
    border-bottom-color: rgb(141, 160, 182);
    border-left-color: rgb(141, 160, 182);
    -unity-text-align: middle-center;
}

.main-tab-view #unity-tab__header:checked {
    background-color: rgb(172, 197, 226);
    border-top-color: rgb(112, 138, 169);
    border-right-color: rgb(112, 138, 169);
    border-bottom-color: rgb(112, 138, 169);
    border-left-color: rgb(112, 138, 169);
}

.main-tab-view #unity-tab-view__content-container,
.main-tab-view #unity-tab__content-container {
    flex-grow: 1;
    min-height: 0;
    align-items: stretch;
    align-self: stretch;
}

.main-tab-view .unity-tab,
.main-tab-view .unity-tab #unity-tab__content-container,
.main-tab-view Tab,
.main-tab-view Tab #unity-tab__content-container {
    flex-grow: 1;
    min-height: 0;
    align-self: stretch;
}

.tab-surface {
    flex-grow: 1;
    min-height: 0;
    padding-top: 12px;
    padding-right: 12px;
    padding-bottom: 12px;
    padding-left: 12px;
    background-color: rgb(240, 246, 252);
    border-top-width: 2px;
