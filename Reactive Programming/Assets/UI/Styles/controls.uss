.category-tab-view #unity-tab-view__header-container .unity-scroll-view__content-viewport,
.category-tab-view #unity-tab-view__header-container #unity-content-viewport {
    overflow: visible;
}

.category-tab-view #unity-tab-view__header-container .unity-scroll-view__content-container,
.category-tab-view #unity-tab-view__header-container #unity-content-container,
.category-tab-view #unity-tab-view__tabs-container {
    flex-direction: row;
    flex-wrap: wrap;
    row-gap: 6px;
    column-gap: 6px;
}

.category-tab-view #unity-tab__header {
    flex-grow: 0;
    flex-shrink: 0;
    min-width: 128px;
    max-width: 128px;
    height: 30px;
    background-color: rgb(209, 223, 239);
    border-top-left-radius: 3px;
    border-top-right-radius: 3px;
    border-bottom-right-radius: 3px;
    border-bottom-left-radius: 3px;
    border-top-width: 1px;
    border-right-width: 1px;
    border-bottom-width: 1px;
    border-left-width: 1px;
    border-top-color: rgb(145, 166, 190);
    border-right-color: rgb(145, 166, 190);
    border-bottom-color: rgb(145, 166, 190);
    border-left-color: rgb(145, 166, 190);
    color: rgb(40, 58, 79);
